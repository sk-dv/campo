rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Templates globales — lectura pública
    match /exercises/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /sessions/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Config global — lectura pública
    match /config/{id} {
      allow read: if true;
      allow write: if false;
    }

    // Datos del usuario — solo el propio usuario
    match /users/{uid}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
