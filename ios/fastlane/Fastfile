default_platform(:ios)

platform :ios do
  desc "Build and upload to TestFlight"
  lane :beta do
    # 1. Autenticación con API Key (sin contraseña)
    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_filepath: ENV["ASC_KEY_FILEPATH"]
    )

    # 2. Provisioning profile
    get_provisioning_profile(
      app_identifier: "io.campo",
      team_id: ENV["TEAM_ID"],
      api_key: api_key
    )

    # 3. Archive y exportar
    build_app(
      workspace: "Runner.xcworkspace",
      scheme: "Runner",
      export_method: "app-store",
      xcargs: "CODE_SIGN_STYLE=Manual CODE_SIGN_IDENTITY='Apple Distribution'",
      export_options: {
        teamID: ENV["TEAM_ID"],
        signingStyle: "manual",
        provisioningProfiles: {
          "io.campo" => lane_context[SharedValues::SIGH_NAME]
        }
      }
    )

    # 4. Subir a TestFlight
    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true
    )
  end
end
